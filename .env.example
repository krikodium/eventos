# ===========================================
# Neon PostgreSQL (Vercel)
# ===========================================
# 1. En Vercel: Project Settings > Storage > Create Database > Neon
# 2. O en neon.tech: crear proyecto y copiar connection string
# 3. La URL pooled (con -pooler en el host) es la recomendada para serverless

DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth
AUTH_SECRET="genera-con-openssl-rand-base64-32"
NEXTAUTH_URL="https://tu-app.vercel.app"

# ===========================================
# Emails transaccionales: Gmail o Resend
# ===========================================
# Recomendado cuando no se dispone del DNS del dominio.
EMAIL_PROVIDER="gmail"
SMTP_USER="cuenta-remitente@gmail.com"
# Contraseña de aplicación de Google; nunca uses la contraseña normal.
SMTP_PASS="xxxx xxxx xxxx xxxx"
EMAIL_FROM="Eventos HC <cuenta-remitente@gmail.com>"

# Alternativa opcional: Resend. Requiere un dominio verificado.
# EMAIL_PROVIDER="resend"
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# EMAIL_FROM="Eventos HC <no-reply@tudominio.com>"
# URL base usada para armar los links de confirmación en los emails.
# Si no se define, cae en NEXTAUTH_URL y luego en http://localhost:3000
APP_URL="https://tu-app.vercel.app"
