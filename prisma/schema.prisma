// Prisma schema - Sistema de Gestión de Eventos Privados
// BD compartida con Shop y Deco (Neon PostgreSQL)
// NO ejecutar prisma migrate deploy - Shop gestiona las migraciones.
// Las tablas de Eventos se crean con eventos-tables.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== TABLAS COMPARTIDAS (Shop) - Solo lectura del schema, no migrar ==========
enum UserRole {
  ADMIN
  VENDEDOR
  VIEWER
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  password       String?
  emailVerified  DateTime?
  image          String?
  role           UserRole  @default(VENDEDOR)
  horarioEntrada String?
  horarioSalida  String?
  diasTrabajo    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ========== TABLAS PROPIAS DE EVENTOS - Usar eventos-tables.sql para crearlas ==========

model Evento {
  id                   String   @id @default(cuid())
  nombre               String
  fecha                DateTime
  fechaFin             DateTime?
  tipo                 String   // CORPORATIVO | PARTICULAR
  cliente              String
  estado               String   @default("BORRADOR") // BORRADOR | CONFIRMADO | EN_CURSO | FINALIZADO | FACTURADO
  descripcion          String?
  organizadora         String?
  provincia            String?
  localidad            String?
  presupuestoTotal     Float?
  presupuestoNro       String?
  formaPagoAcordada    String?
  honorariosHC         Float?
  viaticosArmado       Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  pagosProveedores PagoProveedor[]
  diasUtileros     DiaUtilero[]
  ingresos         Ingreso[]
  cajaChica        CajaChicaEvento[]
}

model Rubro {
  id          String   @id @default(cuid())
  nombre      String   @unique
  proveedores ProveedorEvento[]
  pagos       PagoProveedor[]
}

model ProveedorEvento {
  id          String   @id @default(cuid())
  nombre      String
  rubroId     String
  rubro       Rubro    @relation(fields: [rubroId], references: [id])
  contacto    String?
  cuit        String?
  razonSocial String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pagos PagoProveedor[]

  @@map("ProveedorEvento")
}

model PagoProveedor {
  id           String          @id @default(cuid())
  eventoId     String
  evento       Evento          @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  proveedorId  String
  proveedor    ProveedorEvento @relation(fields: [proveedorId], references: [id])
  rubroId      String
  rubro        Rubro           @relation(fields: [rubroId], references: [id])
  monto        Float
  fecha        DateTime
  concepto     String?
  metodoPago   String          @default("TRANSFERENCIA") // EFECTIVO | TRANSFERENCIA | CHEQUE | OTRO
  createdAt    DateTime        @default(now())

  @@index([eventoId])
  @@index([proveedorId])
}

model Utilero {
  id             String       @id @default(cuid())
  nombre         String
  tarifaPorDia   Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  diasTrabajados DiaUtilero[]
}

model DiaUtilero {
  id        String   @id @default(cuid())
  eventoId  String
  evento    Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  utileroId String
  utilero   Utilero  @relation(fields: [utileroId], references: [id])
  tipo      String   @default("EVENTO") // ARMADO | GUARDIA | DESARME_EVENTO | DESARME_DEPO | EVENTO
  dias      Float
  monto     Float
  createdAt DateTime @default(now())

  @@unique([eventoId, utileroId, tipo])
  @@index([eventoId])
}

model CajaChicaEvento {
  id                String   @id @default(cuid())
  eventoId          String
  evento            Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  monto             Float
  empleadaEncargada String
  concepto          String?
  fecha             DateTime @default(now())

  @@index([eventoId])
  @@map("CajaChicaEvento")
}

model Ingreso {
  id             String   @id @default(cuid())
  eventoId       String
  evento         Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  monto          Float
  concepto       String?
  fecha          DateTime
  tipo           String   @default("FACTURACION") // FACTURACION | ANTICIPO | PAGO_PARCIAL
  numeroFactura  String?
  createdAt      DateTime @default(now())

  @@index([eventoId])
}
